<Window x:Class="Percentage.App.NotifyIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:Percentage.App.Controls"
        xmlns:loc="clr-namespace:Percentage.App.Localization"
        Loaded="OnLoaded"
        ShowInTaskbar="False"
        Left="-100"
        Top="-100"
        Width="0"
        Height="0">
    <controls:SafeNotifyIcon x:Name="NotifyIcon"
                             x:FieldModifier="private"
                             FocusOnLeftClick="False"
                             LeftDoubleClick="OnNotifyIconLeftDoubleClick"
                             LeftClick="OnNotifyIconLeftClick">
        <controls:SafeNotifyIcon.Menu>
            <ContextMenu>
                <ui:MenuItem Header="{loc:Localize Tray_DetailsHeader}"
                             Click="OnDetailsMenuItemClick"
                             Icon="{ui:SymbolIcon AppsListDetail20}"
                             ToolTip="{loc:Localize Tray_DetailsTooltip}" />
                <ui:MenuItem Header="{loc:Localize Tray_AppSettingsHeader}"
                             Click="OnAppSettingsMenuItemClick"
                             Icon="{ui:SymbolIcon Settings20}"
                             ToolTip="{loc:Localize Tray_AppSettingsTooltip}" />
                <ui:MenuItem Header="{loc:Localize Tray_PowerSettingsHeader}"
                             Click="OnSystemSettingsMenuItemClick"
                             Icon="{ui:SymbolIcon FlashSettings20}"
                             ToolTip="{loc:Localize Tray_PowerSettingsTooltip}" />
                <ui:MenuItem Header="{loc:Localize Tray_SleepHeader}"
                             ToolTip="{loc:Localize Tray_SleepTooltip}"
                             Icon="{ui:SymbolIcon WeatherMoon20}"
                             Click="OnSleepMenuItemClick" />
                <ui:MenuItem Header="{loc:Localize Tray_ShutDownHeader}"
                             ToolTip="{loc:Localize Tray_ShutDownTooltip}"
                             Icon="{ui:SymbolIcon Power20}"
                             Click="OnShutDownMenuItemClick" />
                <ui:MenuItem Header="{loc:Localize Tray_AboutHeader}"
                             Click="OnAboutMenuItemClick"
                             Icon="{ui:SymbolIcon Info20}"
                             ToolTip="{loc:Localize Tray_AboutTooltip}" />
                <ui:MenuItem Header="{loc:Localize Tray_ExitHeader}"
                             Click="OnExitMenuItemClick"
                             Icon="{ui:SymbolIcon ArrowExit20}"
                             ToolTip="{loc:Localize Tray_ExitTooltip}" />
            </ContextMenu>
        </controls:SafeNotifyIcon.Menu>
    </controls:SafeNotifyIcon>
</Window>
