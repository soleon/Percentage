<Page x:Class="Percentage.App.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:properties="clr-namespace:Percentage.App.Properties"
      xmlns:system="clr-namespace:System;assembly=System.Runtime"
      xmlns:controls="clr-namespace:Percentage.App.Controls"
      xmlns:loc="clr-namespace:Percentage.App.Localization"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="400">
    <StackPanel>

        <!-- Auto start disabled warning -->
        <ui:InfoBar Title="{loc:Localize Settings_AutoStartDisabledTitle}"
                    Message="{loc:Localize Settings_AutoStartDisabledMessage}"
                    Severity="Warning"
                    IsOpen="True"
                    Visibility="Collapsed"
                    Margin="0,0,0,20"
                    x:Name="AutoStartDisabledInfoBar"
                    x:FieldModifier="private" />

        <!-- Language -->
        <ui:CardControl Icon="{ui:SymbolIcon LocalLanguage20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_LanguageHeader}" />
                    <ui:TextBlock Text="{loc:Localize Settings_LanguageDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="LanguageComboBox"
                      x:FieldModifier="private"
                      DisplayMemberPath="NativeDisplayName"
                      SelectedValuePath="CultureName"
                      SelectedValue="{Binding Language, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
        </ui:CardControl>

        <!-- Auto start -->
        <ui:CardControl Icon="{ui:SymbolIcon CalendarPlay20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_AutoStart}" />
                    <ui:TextBlock Text="{loc:Localize Settings_AutoStartDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="AutoStartToggleSwitch"
                             x:FieldModifier="private"
                             IsEnabled="False"
                             Checked="OnAutoStartChecked"
                             Unchecked="OnAutoStartUnchecked" />
        </ui:CardControl>

        <!-- Hide at startup -->
        <ui:CardControl Icon="{ui:SymbolIcon SlideHide20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_HideAtStartup}" />
                    <ui:TextBlock Text="{loc:Localize Settings_HideAtStartupDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch
                IsChecked="{Binding HideAtStartup, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
        </ui:CardControl>

        <!-- Double click tray icon to activate main UI -->
        <ui:CardControl Icon="{ui:SymbolIcon CursorClick20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_DoubleClickActivation}" />
                    <ui:TextBlock Text="{loc:Localize Settings_DoubleClickActivationDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch
                IsChecked="{Binding DoubleClickActivation, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
        </ui:CardControl>

        <!-- Shut down without confirmation -->
        <ui:CardControl Icon="{ui:SymbolIcon Power20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_ShutDownWithoutConfirmation}" />
                    <ui:TextBlock Text="{loc:Localize Settings_ShutDownWithoutConfirmationDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch
                IsChecked="{Binding ShutDownWithoutConfirmation, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
        </ui:CardControl>

        <!-- Refresh interval -->
        <ui:CardControl Icon="{ui:SymbolIcon ArrowSync20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_Refresh}" />
                    <ui:TextBlock Text="{loc:Localize Settings_RefreshDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox
                SelectedValue="{Binding RefreshSeconds, Source={x:Static properties:Settings.Default}, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding Converter="{x:Static loc:LocalizedFormatConverter.Instance}">
                                    <Binding Path="[Settings_RefreshSecondsFormat]"
                                             Source="{x:Static loc:LocalizationManager.Instance}" />
                                    <Binding />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                <system:Int32>5</system:Int32>
                <system:Int32>10</system:Int32>
                <system:Int32>30</system:Int32>
                <system:Int32>60</system:Int32>
            </ComboBox>
        </ui:CardControl>

        <!-- Tray icon font -->
        <ui:CardExpander Icon="{ui:SymbolIcon TextFont20}">
            <ui:CardExpander.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_TrayIconFont}" />
                    <ui:TextBlock Text="{loc:Localize Settings_TrayIconFontDescription}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <StackPanel>
                <DockPanel>
                    <ToggleButton Content="{ui:SymbolIcon TextUnderline20}"
                                  VerticalAlignment="Stretch"
                                  IsChecked="{Binding TrayIconFontUnderline, Source={x:Static properties:Settings.Default}}"
                                  DockPanel.Dock="Right"
                                  Margin="5,0,0,0" />
                    <ToggleButton Content="{ui:SymbolIcon TextBold20}"
                                  VerticalAlignment="Stretch"
                                  IsChecked="{Binding TrayIconFontBold, Source={x:Static properties:Settings.Default}}"
                                  DockPanel.Dock="Right" />
                    <ComboBox Margin="0,0,5,0"
                              SelectedItem="{Binding TrayIconFontFamily, Source={x:Static properties:Settings.Default}}"
                              ItemsSource="{x:Static Fonts.SystemFontFamilies}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="{Binding}"
                                           Text="{Binding Source}"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="{loc:Localize Settings_FontSize}" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding TrayIconFontSize, Source={x:Static properties:Settings.Default}}" />
                    <Slider Margin="12"
                            TickPlacement="Both"
                            Minimum="4"
                            Maximum="28"
                            IsSnapToTickEnabled="True"
                            Value="{Binding TrayIconFontSize, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
                </DockPanel>
            </StackPanel>
        </ui:CardExpander>

        <!-- Tray icon colour -->
        <ui:CardExpander Icon="{ui:SymbolIcon Color20}">
            <ui:CardExpander.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_TrayIconColour}" />
                    <ui:TextBlock Text="{loc:Localize Settings_TrayIconColourDescription}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <Grid IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="5" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <controls:AccentColourPicker Label="{loc:Localize Settings_LevelCritical}"
                                             IsAutoColour="{Binding IsAutoBatteryCriticalColour, Source={x:Static properties:Settings.Default}}"
                                             SelectedColour="{Binding BatteryCriticalColour, Source={x:Static properties:Settings.Default}}" />
                <controls:AccentColourPicker Grid.Row="0"
                                             Grid.Column="2"
                                             Label="{loc:Localize Settings_LevelLow}"
                                             IsAutoColour="{Binding IsAutoBatteryLowColour, Source={x:Static properties:Settings.Default}}"
                                             SelectedColour="{Binding BatteryLowColour, Source={x:Static properties:Settings.Default}}" />
                <Rectangle Grid.RowSpan="3"
                           Grid.Row="0"
                           Grid.Column="1"
                           VerticalAlignment="Stretch"
                           Width="1"
                           Margin="8"
                           Fill="{ui:ThemeResource ControlElevationBorderBrush}" />
                <controls:AccentColourPicker Grid.Row="2"
                                             Grid.Column="0"
                                             Label="{loc:Localize Settings_LevelCharging}"
                                             IsAutoColour="{Binding IsAutoBatteryChargingColour, Source={x:Static properties:Settings.Default}}"
                                             SelectedColour="{Binding BatteryChargingColour, Source={x:Static properties:Settings.Default}}" />
                <controls:AccentColourPicker Grid.Row="2"
                                             Grid.Column="2"
                                             Label="{loc:Localize Settings_LevelNormal}"
                                             SelectedColour="{Binding BatteryNormalColour, Source={x:Static properties:Settings.Default}}"
                                             IsAutoColour="{Binding IsAutoBatteryNormalColour, Source={x:Static properties:Settings.Default}}" />
            </Grid>
        </ui:CardExpander>

        <!-- Tray icon background colour -->
        <ui:CardExpander Icon="{ui:SymbolIcon Color20}">
            <ui:CardExpander.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_TrayIconBackgroundColour}" />
                    <ui:TextBlock Text="{loc:Localize Settings_TrayIconBackgroundColourDescription}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <Grid IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="5" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <controls:AccentColourPicker Label="{loc:Localize Settings_LevelCritical}"
                                             IsAutoTransparent="True"
                                             IsAutoColour="{Binding IsAutoBatteryCriticalBackgroundColour, Source={x:Static properties:Settings.Default}}"
                                             SelectedColour="{Binding BatteryCriticalBackgroundColour, Source={x:Static properties:Settings.Default}}" />
                <controls:AccentColourPicker Grid.Row="0"
                                             Grid.Column="2"
                                             Label="{loc:Localize Settings_LevelLow}"
                                             IsAutoTransparent="True"
                                             IsAutoColour="{Binding IsAutoBatteryLowBackgroundColour, Source={x:Static properties:Settings.Default}}"
                                             SelectedColour="{Binding BatteryLowBackgroundColour, Source={x:Static properties:Settings.Default}}" />
                <Rectangle Grid.RowSpan="3"
                           Grid.Row="0"
                           Grid.Column="1"
                           VerticalAlignment="Stretch"
                           Width="1"
                           Margin="8"
                           Fill="{ui:ThemeResource ControlElevationBorderBrush}" />
                <controls:AccentColourPicker Grid.Row="2"
                                             Grid.Column="0"
                                             Label="{loc:Localize Settings_LevelCharging}"
                                             IsAutoTransparent="True"
                                             IsAutoColour="{Binding IsAutoBatteryChargingBackgroundColour, Source={x:Static properties:Settings.Default}}"
                                             SelectedColour="{Binding BatteryChargingBackgroundColour, Source={x:Static properties:Settings.Default}}" />
                <controls:AccentColourPicker Grid.Row="2"
                                             Grid.Column="2"
                                             Label="{loc:Localize Settings_LevelNormal}"
                                             IsAutoTransparent="True"
                                             SelectedColour="{Binding BatteryNormalBackgroundColour, Source={x:Static properties:Settings.Default}}"
                                             IsAutoColour="{Binding IsAutoBatteryNormalBackgroundColour, Source={x:Static properties:Settings.Default}}" />
            </Grid>
        </ui:CardExpander>

        <!-- Battery levels and notifications -->
        <ui:CardExpander Icon="{ui:SymbolIcon Battery520}">
            <ui:CardExpander.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_BatteryLevelsAndNotifications}" />
                    <ui:TextBlock Text="{loc:Localize Settings_BatteryLevelsAndNotificationsDescription}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <StackPanel Grid.IsSharedSizeScope="True">
                <controls:BatteryLevelNotificationSetter x:Name="CriticalBatteryLevelNotificationSetter"
                                                         x:FieldModifier="private"
                                                         StatusName="{loc:Localize Settings_LevelCritical}"
                                                         Value="{Binding BatteryCriticalNotificationValue, Source={x:Static properties:Settings.Default}, Mode=TwoWay}"
                                                         IsChecked="{Binding BatteryCriticalNotification, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
                <controls:BatteryLevelNotificationSetter StatusName="{loc:Localize Settings_LevelLow}"
                                                         Margin="0,12"
                                                         Value="{Binding BatteryLowNotificationValue, Source={x:Static properties:Settings.Default}, Mode=TwoWay}"
                                                         IsChecked="{Binding BatteryLowNotification, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
                <controls:BatteryLevelNotificationSetter StatusName="{loc:Localize Settings_LevelHigh}"
                                                         Value="{Binding BatteryHighNotificationValue, Source={x:Static properties:Settings.Default}, Mode=TwoWay}"
                                                         IsChecked="{Binding BatteryHighNotification, Source={x:Static properties:Settings.Default}, Mode=TwoWay}" />
                <Grid Height="{Binding ActualHeight, ElementName=CriticalBatteryLevelNotificationSetter}"
                      Margin="0,12,0,0">
                    <TextBlock Text="{loc:Localize Settings_LevelFull}" />
                    <ui:ToggleSwitch HorizontalAlignment="Right"
                                     IsChecked="{Binding BatteryFullNotification, Source={x:Static properties:Settings.Default}}" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <!-- Open system power settings -->
        <ui:CardControl Icon="{ui:SymbolIcon FlashSettings20}"
                        Content="{ui:SymbolIcon Open20}"
                        Click="OnSystemPowerSettingsClick">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="{loc:Localize Settings_PowerAndBattery}" />
                    <ui:TextBlock Text="{loc:Localize Settings_PowerAndBatteryDescription}" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <!-- Reset all settings button -->
        <ui:Button Appearance="Caution"
                   HorizontalAlignment="Right"
                   Content="{loc:Localize Settings_ResetAll}"
                   Icon="{ui:SymbolIcon ErrorCircle20}"
                   Click="OnResetButtonClick" />
    </StackPanel>
</Page>
